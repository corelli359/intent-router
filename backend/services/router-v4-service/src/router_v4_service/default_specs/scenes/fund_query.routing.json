{
  "scene_id": "fund_query",
  "version": "0.1.0",
  "name": "基金查询",
  "description": "识别用户查询基金详情、风险、收益、持仓或产品信息的请求，并派发给基金执行 Agent。",
  "target_agent": "fund-agent",
  "triggers": {
    "keywords": ["基金", "QDII", "ETF", "净值", "持仓", "收益", "风险等级"],
    "negative_keywords": ["转账", "汇款"],
    "examples": ["沪深300ETF怎么样", "我想了解QDII基金"],
    "negative_examples": ["给张三转5000块"]
  },
  "routing_slots": [
    {
      "name": "fund_name",
      "source": "user_utterance",
      "required_for_dispatch": false,
      "handoff": true,
      "extractor": {
        "type": "after_terms",
        "terms": ["了解", "看看", "查询", "买"],
        "stop_terms": ["怎么样", "如何", "基金"],
        "max_chars": 24
      }
    }
  ],
  "dispatch_contract": {
    "task_type": "fund_query",
    "handoff_fields": ["raw_message", "fund_name", "user_profile_ref", "page_context_ref"]
  },
  "references": ["fund-routing.md"]
}
