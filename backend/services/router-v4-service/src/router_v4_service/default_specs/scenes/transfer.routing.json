{
  "scene_id": "transfer",
  "version": "0.1.0",
  "name": "转账",
  "description": "识别用户向他人转账、汇款、打款的请求，并派发给转账执行 Agent。",
  "target_agent": "transfer-agent",
  "triggers": {
    "keywords": ["转账", "转给", "汇款", "打钱", "打款"],
    "negative_keywords": ["记录", "明细", "历史"],
    "examples": ["给张三转5000块", "向李四汇款"],
    "negative_examples": ["查询转账记录"]
  },
  "routing_slots": [
    {
      "name": "recipient",
      "source": "user_utterance",
      "required_for_dispatch": false,
      "handoff": true,
      "extractor": {
        "type": "after_terms",
        "terms": ["转给", "给", "向"],
        "stop_terms": ["转账", "汇款", "打钱", "打款", "转", "支付"],
        "max_chars": 16
      }
    },
    {
      "name": "amount",
      "source": "user_utterance",
      "required_for_dispatch": false,
      "handoff": true,
      "extractor": {
        "type": "number"
      }
    }
  ],
  "dispatch_contract": {
    "task_type": "transfer",
    "handoff_fields": ["raw_message", "recipient", "amount", "user_profile_ref", "page_context_ref"]
  },
  "references": ["transfer-routing.md"]
}
